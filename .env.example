# Alliance of Coders - environment variable template.
# Copy to .env and fill in real values. Never commit .env.
# Per 06-security-architecture.md section 8: secrets stay out of source control.

# --- Required ---
# SQLite (dev): file:./db/custom.db  (relative to the directory the dev server is started in - typically the project root)
# Postgres (prod): postgresql://user:pass@host:5432/db?schema=public
DATABASE_URL="file:./db/custom.db"

# --- Optional: public site config (safe to expose to client) ---
# Canonical site URL (no trailing slash). Used for SEO metadata, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL="https://allianceofcoders.ph"
# Social links - leave empty to hide the link from the footer (no hardcoded fallbacks).
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_GITHUB_URL=""
NEXT_PUBLIC_CONTACT_EMAIL="allianceofcoders@ctu.edu.ph"

# --- Optional: Supabase (required in production for image storage) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only - never prefixed with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=""

# --- Optional: security tuning ---
# Comma-separated extra origins allowed for CSRF (staging/preview URLs)
CSRF_ALLOWED_ORIGINS=""
# Comma-separated extra image hosts for CSP img-src
IMG_ALLOWED_HOSTS=""

# --- Set automatically by Next.js ---
# NODE_ENV: development | test | production
